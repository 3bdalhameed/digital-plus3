# ─── PostgreSQL ────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password_here

# ─── Payload CMS ───────────────────────────────────────────
PAYLOAD_SECRET=change_me_32_char_secret_minimum
PAYLOAD_INTERNAL_SECRET=change_me_shared_secret_between_apps
CMS_PUBLIC_URL=https://cms.yourdomain.com
PREVIEW_SECRET=change_me_preview_secret

# ─── Storefront ────────────────────────────────────────────
STOREFRONT_PUBLIC_URL=https://yourdomain.com

# ─── NextAuth (Auth.js v5) ─────────────────────────────────
NEXTAUTH_SECRET=change_me_nextauth_secret_64_chars
# Public HTTPS origin of the storefront. Required behind a reverse proxy
# (Cloudflare/Coolify) — without it NextAuth mis-derives the scheme and
# sign-in fails with "MissingCSRF". Set AUTH_* (v5) to the same values.
NEXTAUTH_URL=https://yourdomain.com
AUTH_URL=https://yourdomain.com
AUTH_TRUST_HOST=true
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# ─── Resend (Email) ────────────────────────────────────────
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── Cron Security ─────────────────────────────────────────
CRON_SECRET=change_me_cron_secret

# ─── Cloudflare R2 (Media Storage) ─────────────────────────
S3_BUCKET=your-r2-bucket-name
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your_r2_access_key_id
S3_SECRET_ACCESS_KEY=your_r2_secret_access_key
S3_REGION=auto
S3_PUBLIC_URL=https://your-r2-public-domain.r2.dev

# ─── Airwallex (Payments — optional) ───────────────────────
AIRWALLEX_CLIENT_ID=
AIRWALLEX_API_KEY=
AIRWALLEX_WEBHOOK_SECRET=
AIRWALLEX_ENV=demo
