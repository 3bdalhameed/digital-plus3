{
  "name": "cms",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts nodemon",
    "build:payload": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload build",
    "build:server": "tsc",
    "build": "pnpm build:payload && pnpm build:server",
    "serve": "cross-env PAYLOAD_CONFIG_PATH=dist/payload.config.js node dist/server.js",
    "generate:types": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload generate:types",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@payloadcms/bundler-webpack": "^1.0.7",
    "@payloadcms/db-postgres": "^0.8.0",
    "@payloadcms/plugin-cloud-storage": "^1.2.2",
    "@payloadcms/richtext-lexical": "^0.11.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "payload": "^2.30.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "csv-parse": "^6.2.1",
    "form-data": "^4.0.5",
    "nodemon": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
