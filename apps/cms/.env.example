# Database (Supabase PostgreSQL)
# Get this from Supabase → Project Settings → Database → Connection string
DATABASE_URI=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# Payload Secret (minimum 32 characters — generate a random one)
PAYLOAD_SECRET=CHANGE-ME-generate-a-random-secret-here-min-32

# Public URL
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001

# Port
PORT=3001

# Storefront URL (for CORS)
STOREFRONT_URL=http://localhost:3000

# Cloudflare R2 (S3-compatible) — OPTIONAL for MVP, media will use local storage
# S3_BUCKET=my-store-media
# S3_ACCESS_KEY_ID=your-r2-access-key
# S3_SECRET_ACCESS_KEY=your-r2-secret-key
# S3_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
# S3_REGION=auto
