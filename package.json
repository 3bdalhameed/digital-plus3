{
  "name": "my-store",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel dev",
    "dev:storefront": "pnpm --filter storefront dev",
    "dev:cms": "pnpm --filter cms dev",
    "build": "pnpm --filter storefront build && pnpm --filter cms build",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
